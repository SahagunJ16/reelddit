# ---------------------------------------------------------------------------
# Reelddit — environment variables
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# ===========================================================================
# REQUIRED
# ===========================================================================

# --- Auth.js / NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Public base URL of the app (no trailing slash).
#   - Local dev:  http://localhost:3000
#   - On Vercel:  leave UNSET — Auth.js auto-detects from the deployment URL
#                 (trustHost is enabled). Set it only if you use a custom domain.
AUTH_URL=http://localhost:3000

# --- Reddit OAuth app ---
# Create an app at https://www.reddit.com/prefs/apps (type: "web app").
# Redirect URI must be EXACTLY: <your-base-url>/api/auth/callback/reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Reddit requires a descriptive, unique User-Agent on every API call.
# Format: platform:app-id:version (by /u/yourusername)
REDDIT_USER_AGENT=web:reelddit:0.1.0 (by /u/your_reddit_username)

# ===========================================================================
# OPTIONAL — Supabase token storage (CURRENTLY ON HOLD)
# ===========================================================================
# Leave these UNSET to keep Supabase disabled. While unset, Reddit tokens live
# only in the encrypted Auth.js session cookie, and user settings live in the
# browser (localStorage / sessionStorage). The DB layer is fully dormant.
#
# To re-enable later: run supabase/schema.sql, then set all three values.
# TOKEN_ENCRYPTION_KEY is only used to encrypt tokens before they hit Postgres,
# so it is only needed when Supabase is enabled. Generate: openssl rand -base64 32
#
# TOKEN_ENCRYPTION_KEY=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

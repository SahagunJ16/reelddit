# ---------------------------------------------------------------------------
# Reddit Reels — environment variables
# Copy this file to `.env.local` and fill in the values.
# ---------------------------------------------------------------------------

# --- Auth.js / NextAuth ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Public base URL of the app (no trailing slash). For local dev:
NEXTAUTH_URL=http://localhost:3000

# --- Reddit OAuth app ---
# Create an app at https://www.reddit.com/prefs/apps (type: "web app").
# Redirect URI must be: <NEXTAUTH_URL>/api/auth/callback/reddit
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Reddit requires a descriptive, unique User-Agent on every API call.
# Format: platform:app-id:version (by /u/yourusername)
REDDIT_USER_AGENT=web:reelddit:0.1.0 (by /u/your_reddit_username)

# --- Token encryption ---
# 32-byte key (base64 or hex) used to encrypt Reddit tokens at rest.
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# --- Supabase (Postgres token storage) ---
# Project URL + service role key (server-side only — never expose to client).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
